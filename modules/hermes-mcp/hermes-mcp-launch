#!/usr/bin/env bash
# Lightweight Hermes MCP launcher hook
# Detects when cwd is inside the Oligarchy flake and sets HERMES_MCP_FLAKE_DIR
# so Hermes Agent automatically discovers the local hermes-mcp server.

set -euo pipefail

# Walk up from cwd to find flake.nix (handles subdirectories)
dir="$(pwd)"
flake_dir=""
while [[ "$dir" != "/" ]]; do
  if [[ -f "$dir/flake.nix" ]]; then
    # Verify this is the Oligarchy flake (quick heuristic)
    if grep -q 'Oligarchy' "$dir/flake.nix" 2>/dev/null || \
       [[ -d "$dir/modules/hermes-mcp" ]]; then
      flake_dir="$dir"
      break
    fi
  fi
  dir="$(dirname "$dir")"
done

if [[ -n "$flake_dir" ]]; then
  export HERMES_MCP_FLAKE_DIR="$flake_dir"
fi

# Exec the real hermes-mcp (must be in PATH)
exec hermes-mcp "$@"
